#import <UIKit/UIKit.h>

NS_ASSUME_NONNULL_BEGIN

NS_INLINE NSBundle *{{ job.swiftIdentifier }}Bundle(void) {
{% if bundle.mode == "main" -%}
    return NSBundle.mainBundle;
{% elif bundle.mode == "module" -%}
#if defined(SWIFTPM_MODULE_BUNDLE)
    return SWIFTPM_MODULE_BUNDLE;
#else
    @throw [NSException exceptionWithName:NSInternalInconsistencyException
                                   reason:@"SWIFTPM_MODULE_BUNDLE is unavailable for module-scoped ObjC resources."
                                 userInfo:nil];
#endif
{% elif bundle.mode == "custom" -%}
    NSBundle *bundle = [NSBundle bundleWithIdentifier:{{ bundle.identifier | objc_string_literal }}];
    if (bundle == nil) {
        @throw [NSException exceptionWithName:NSInternalInconsistencyException
                                       reason:{{ ("Missing configured bundle identifier: " ~ bundle.identifier) | objc_string_literal }}
                                     userInfo:nil];
    }
    return bundle;
{% else -%}
    @throw [NSException exceptionWithName:NSInternalInconsistencyException
                                   reason:{{ ("Unsupported bundle mode: " ~ bundle.mode) | objc_string_literal }}
                                 userInfo:nil];
{% endif -%}
}

{% macro render_entries(entries, prefix) -%}
{% for entry in entries -%}
{% if entry.kind == "namespace" -%}
{{ render_entries(entry.children, prefix ~ entry.swiftIdentifier) }}{% elif entry.kind == "color" -%}
NS_INLINE UIColor *{{ job.swiftIdentifier }}{{ prefix }}{{ entry.swiftIdentifier }}(void) {
    UIColor *color = [UIColor colorNamed:{{ entry.properties.assetName | objc_string_literal }} inBundle:{{ job.swiftIdentifier }}Bundle() compatibleWithTraitCollection:nil];
    if (color == nil) {
        @throw [NSException exceptionWithName:NSInternalInconsistencyException
                                       reason:[NSString stringWithFormat:@"Missing color asset: %@", {{ entry.properties.assetName | objc_string_literal }}]
                                     userInfo:nil];
    }
    return color;
}

{% elif entry.kind == "image" -%}
NS_INLINE UIImage *{{ job.swiftIdentifier }}{{ prefix }}{{ entry.swiftIdentifier }}(void) {
    UIImage *image = [UIImage imageNamed:{{ entry.properties.assetName | objc_string_literal }} inBundle:{{ job.swiftIdentifier }}Bundle() compatibleWithTraitCollection:nil];
    if (image == nil) {
        @throw [NSException exceptionWithName:NSInternalInconsistencyException
                                       reason:[NSString stringWithFormat:@"Missing image asset: %@", {{ entry.properties.assetName | objc_string_literal }}]
                                     userInfo:nil];
    }
    return image;
}

{% endif -%}
{% endfor -%}
{%- endmacro %}
{% for module in modules %}
{{ render_entries(module.entries, module.name) }}{% endfor -%}
NS_ASSUME_NONNULL_END
