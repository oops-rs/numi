#import <Foundation/Foundation.h>

NS_ASSUME_NONNULL_BEGIN

{% macro render_entries(entries, prefix, indent) -%}
{% for entry in entries -%}
{% if entry.kind == "namespace" -%}
{{ render_entries(entry.children, prefix ~ entry.swiftIdentifier, indent) }}{% elif entry.kind == "data" -%}
{{ indent }}+ (NSURL *){{ (prefix ~ entry.swiftIdentifier) | lower_first }};
{% endif -%}
{% endfor -%}
{%- endmacro %}
{% macro render_entry_implementations(entries, prefix, indent) -%}
{% for entry in entries -%}
{% if entry.kind == "namespace" -%}
{{ render_entry_implementations(entry.children, prefix ~ entry.swiftIdentifier, indent) }}{% elif entry.kind == "data" -%}
{{ indent }}+ (NSURL *){{ (prefix ~ entry.swiftIdentifier) | lower_first }} {
{{ indent }}    return [self fileURLForPath:{{ entry.properties.relativePath | string_literal }}];
{{ indent }}}

{% endif -%}
{% endfor -%}
{%- endmacro %}
{% for module in modules %}
@interface {{ job.swiftIdentifier }}{{ module.name }} : NSObject
{{ render_entries(module.entries, "", "") }}+ (NSBundle *)resourceBundle;
+ (NSURL *)fileURLForPath:(NSString *)path;
@end

@implementation {{ job.swiftIdentifier }}{{ module.name }}
{{ render_entry_implementations(module.entries, "", "") }}+ (NSBundle *)resourceBundle {
{% if bundle.mode == "main" -%}
    return NSBundle.mainBundle;
{% elif bundle.mode == "module" -%}
    return [NSBundle bundleForClass:self];
{% else -%}
    return [NSBundle bundleWithIdentifier:{{ bundle.identifier | string_literal }}] ?: NSBundle.mainBundle;
{% endif -%}
}

+ (NSURL *)fileURLForPath:(NSString *)path {
    NSURL *url = [[self resourceBundle] URLForResource:path withExtension:nil];
    if (url == nil) {
        @throw [NSException exceptionWithName:NSInternalInconsistencyException
                                       reason:[NSString stringWithFormat:@"Missing file resource: %@", path]
                                     userInfo:nil];
    }
    return url;
}
@end

{% endfor -%}
NS_ASSUME_NONNULL_END
