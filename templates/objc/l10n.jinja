#import <Foundation/Foundation.h>

NS_ASSUME_NONNULL_BEGIN

{% macro render_entries(entries, prefix, indent, table_name) -%}
{% for entry in entries -%}
{% if entry.kind == "namespace" -%}
{{ render_entries(entry.children, prefix ~ entry.swiftIdentifier, indent, table_name) }}{% elif entry.kind == "string" -%}
{{ indent }}+ (NSString *){{ (prefix ~ entry.swiftIdentifier) | lower_first }};
{% endif -%}
{% endfor -%}
{%- endmacro %}
{% macro render_entry_implementations(entries, prefix, indent, table_name) -%}
{% for entry in entries -%}
{% if entry.kind == "namespace" -%}
{{ render_entry_implementations(entry.children, prefix ~ entry.swiftIdentifier, indent, table_name) }}{% elif entry.kind == "string" -%}
{{ indent }}+ (NSString *){{ (prefix ~ entry.swiftIdentifier) | lower_first }} {
{{ indent }}    return NSLocalizedStringWithDefaultValue({{ entry.properties.key | string_literal }}, {{ table_name | string_literal }}, [self resourceBundle], @"", @"");
{{ indent }}}

{% endif -%}
{% endfor -%}
{%- endmacro %}
{% for module in modules %}
@interface {{ job.swiftIdentifier }}{{ module.name }} : NSObject
{{ render_entries(module.entries, "", "", module.properties.tableName) }}+ (NSBundle *)resourceBundle;
@end

@implementation {{ job.swiftIdentifier }}{{ module.name }}
{{ render_entry_implementations(module.entries, "", "", module.properties.tableName) }}+ (NSBundle *)resourceBundle {
{% if bundle.mode == "main" -%}
    return NSBundle.mainBundle;
{% elif bundle.mode == "module" -%}
    return [NSBundle bundleForClass:self];
{% else -%}
    return [NSBundle bundleWithIdentifier:{{ bundle.identifier | string_literal }}] ?: NSBundle.mainBundle;
{% endif -%}
}
@end

{% endfor -%}
NS_ASSUME_NONNULL_END
