#import <Foundation/Foundation.h>

NS_ASSUME_NONNULL_BEGIN

NS_INLINE NSBundle *{{ job.swiftIdentifier }}Bundle(void) {
{% if bundle.mode == "main" -%}
    return NSBundle.mainBundle;
{% elif bundle.mode == "module" -%}
#if defined(SWIFTPM_MODULE_BUNDLE)
    return SWIFTPM_MODULE_BUNDLE;
#else
    @throw [NSException exceptionWithName:NSInternalInconsistencyException
                                   reason:@"SWIFTPM_MODULE_BUNDLE is unavailable for module-scoped ObjC resources."
                                 userInfo:nil];
#endif
{% else -%}
    NSBundle *bundle = [NSBundle bundleWithIdentifier:{{ bundle.identifier | objc_string_literal }}];
    if (bundle == nil) {
        @throw [NSException exceptionWithName:NSInternalInconsistencyException
                                       reason:{{ ("Missing configured bundle identifier: " ~ bundle.identifier) | objc_string_literal }}
                                     userInfo:nil];
    }
    return bundle;
{% endif -%}
}

{% macro render_entries(entries, prefix, table_name) -%}
{% for entry in entries -%}
{% if entry.kind == "namespace" -%}
{{ render_entries(entry.children, prefix ~ entry.swiftIdentifier, table_name) }}{% elif entry.kind == "string" -%}
NS_INLINE NSString *{{ job.swiftIdentifier }}{{ prefix }}{{ entry.swiftIdentifier }}(void) {
    return NSLocalizedStringWithDefaultValue({{ entry.properties.key | objc_string_literal }}, {{ table_name | objc_string_literal }}, {{ job.swiftIdentifier }}Bundle(), @"", @"");
}

{% endif -%}
{% endfor -%}
{%- endmacro %}
{% for module in modules %}
{{ render_entries(module.entries, module.name, module.properties.tableName) }}{% endfor -%}
NS_ASSUME_NONNULL_END
